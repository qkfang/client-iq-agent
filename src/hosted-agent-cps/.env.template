# =============================================================================
# Copilot Studio agent (Power Platform Direct-to-Engine)
# =============================================================================
# Power Platform environment ID hosting the Copilot Studio agent
ENVIRONMENT_ID=<your-environment-id>

# Copilot Studio agent schema name / identifier
AGENT_IDENTIFIER=<your-copilot-studio-agent-schema-name>

# =============================================================================
# Microsoft Entra app registration used to authenticate to Copilot Studio
# =============================================================================
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-app-registration-client-id>
AZURE_CLIENT_SECRET=<your-app-registration-client-secret>
