# =============================================================================
# Copilot Studio agent (Direct Line channel)
# =============================================================================
# The agent must be published and configured with "No Authentication"
# (Copilot Studio > Settings > Security > Authentication).

# Power Platform environment ID hosting the Copilot Studio agent
ENVIRONMENT_ID=<your-environment-id>

# Copilot Studio agent schema name / identifier
AGENT_IDENTIFIER=<your-agent-schema-name>

# Optional: explicit Direct Line token endpoint. When omitted it is derived
# from ENVIRONMENT_ID and AGENT_IDENTIFIER.
# DIRECTLINE_TOKEN_ENDPOINT=
