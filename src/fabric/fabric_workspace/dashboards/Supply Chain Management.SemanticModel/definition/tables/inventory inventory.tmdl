		annotation UnderlyingDateTimeDataType = Date

	column StockHealth =
			
			SWITCH(
			    TRUE(),
			    'inventory Inventory'[CurrentStock] = 0, "Out of Stock",
			    'inventory Inventory'[CurrentStock] <= 'inventory Inventory'[SafetyStockLevel], "Low Stock",
			    'inventory Inventory'[CurrentStock] <= 'inventory Inventory'[ReorderPoint], "Reorder Soon",
			    'inventory Inventory'[CurrentStock] >= 'inventory Inventory'[MaxStockLevel] * 0.9, "High Stock",
			    "Healthy Stock"
			)
		lineageTag: bcd304dd-2c70-4a32-8b6d-ffa35fdfa786
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

