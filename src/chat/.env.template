# Azure AI Search (set from azd outputs)
# AZURE_AI_SEARCH_ENDPOINT comes from infra/main.bicep output AZURE_AI_SEARCH_ENDPOINT.
AZURE_AI_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
# Optional legacy alias; leave equal to AZURE_AI_SEARCH_ENDPOINT when used.
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_API_VERSION=2025-11-01-preview

# Public endpoint used by browser-side MCP URL generation.
NEXT_PUBLIC_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
NEXT_PUBLIC_AZURE_AI_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
NEXT_PUBLIC_AZURE_SEARCH_API_VERSION=2025-11-01-preview

# Azure AI Foundry project (set from azd outputs AZURE_AI_PROJECT_ENDPOINT / AZURE_AI_AGENT_ENDPOINT)
FOUNDRY_PROJECT_ENDPOINT=https://<ai-account>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=https://<ai-account>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_AGENT_ENDPOINT=https://<ai-account>.services.ai.azure.com/api/projects/<project-name>
NEXT_PUBLIC_FOUNDRY_PROJECT_ENDPOINT=https://<ai-account>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_API_VERSION=2025-05-01
FOUNDRY_ASSISTANTS_API_VERSION=2024-05-01-preview

# Foundry resource metadata for management-plane queries
# AI_FOUNDRY_RESOURCE_ID comes from infra/main.bicep output AI_FOUNDRY_RESOURCE_ID.
AI_FOUNDRY_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.CognitiveServices/accounts/<ai-account>
AZURE_AI_PROJECT_NAME=<project-name>
AZURE_RESOURCE_GROUP=<resource-group>
AZURE_SUBSCRIPTION_ID=<subscription-id>

# Azure OpenAI model configuration (set from azd outputs)
AZURE_OPENAI_ENDPOINT=https://<ai-account>.openai.azure.com/
NEXT_PUBLIC_AZURE_OPENAI_ENDPOINT=https://<ai-account>.openai.azure.com/
NEXT_PUBLIC_AZURE_OPENAI_DEFAULT_MODEL=<AZURE_OPENAI_DEPLOYMENT_MODEL>
NEXT_PUBLIC_AZURE_OPENAI_EMBEDDING_MODEL=<AZURE_OPENAI_EMBEDDING_MODEL>

# Azure AD authentication for local development or deployment
# Use service-principal, managed-identity, or default.
AZURE_AUTH_METHOD=service-principal
AZURE_TENANT_ID=<tenant-id>
AZURE_CLIENT_ID=<client-id>
AZURE_CLIENT_SECRET=<client-secret>
# Optional when using a user-assigned managed identity.
AZURE_MANAGED_IDENTITY_CLIENT_ID=<managed-identity-client-id>
