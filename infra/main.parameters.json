{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "solutionName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "existingFabricCapacityName": {
      "value": "${AZURE_EXISTING_FABRIC_CAPACITY_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "skuName": {
      "value": "${FABRIC_CAPACITY_SKU_NAME}"
    },
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "AZURE_LOCATION": {
      "value": "${AZURE_LOCATION}"
    },
    "secondaryLocation": {
      "value": "${AZURE_SECONDARY_LOCATION}"
    },
    "deploymentType": {
      "value": "${AZURE_OPENAI_MODEL_DEPLOYMENT_TYPE}"
    },
    "gptModelName": {
      "value": "${AZURE_OPENAI_DEPLOYMENT_MODEL}"
    },
    "gptModelVersion": {
      "value": "${AZURE_ENV_MODEL_VERSION}"
    },
    "azureOpenAIApiVersion": {
      "value": "${AZURE_OPENAI_API_VERSION}"
    },
    "gptDeploymentCapacity": {
      "value": "${AZURE_OPENAI_DEPLOYMENT_MODEL_CAPACITY}"
    },
    "imageTag": {
      "value": "${AZURE_ENV_IMAGETAG}"
    },
    "existingLogAnalyticsWorkspaceId": {
      "value": "${AZURE_ENV_LOG_ANALYTICS_WORKSPACE_ID}"
    },
    "azureExistingAIProjectResourceId": {
      "value": "${AZURE_EXISTING_AI_PROJECT_RESOURCE_ID}"
    },
    "backendRuntimeStack": {
      "value": "${BACKEND_RUNTIME_STACK}"
    },
    "aiDeploymentsLocation": {
      "value": "${AZURE_ENV_AI_DEPLOYMENTS_LOCATION}"
    },
    "acrName": {
      "value": "${AZURE_ENV_ACR_NAME}"
    },
    "usecase": {
      "value": "${AZURE_ENV_USE_CASE}"
    },
    "searchServiceLocation": {
      "value": "${AZURE_ENV_SEARCH_SERVICE_LOCATION}"
    },
    "deployApp": {
      "value": "${AZURE_ENV_DEPLOY_APP=true}"
    },
    "isWorkshop": {
      "value": "${IS_WORKSHOP=true}"
    },
    "azureEnvOnly": {
      "value": "${AZURE_ENV_ONLY=false}"
    },
    "deployingUserPrincipalType": {
      "value": "${DEPLOYING_USER_PRINCIPAL_TYPE=User}"
    },
    "workiqTenantId": {
      "value": "${WORKIQ_TENANT_ID=common}"
    },
    "workiqEndpoint": {
      "value": "${WORKIQ_ENDPOINT=http://localhost:3000/mcp}"
    },
    "workiqMcpConnectionName": {
      "value": "${WORKIQ_MCP_CONNECTION_NAME=}"
    }
  }
}